{
  "name": "openremit",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "bot": "tsx bot/src/index.ts",
    "build": "npm run build --workspaces --if-present",
    "db:push": "npm run db:push --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.6.4"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "express": "^5.2.1",
    "grammy": "^1.44.0"
  }
}
