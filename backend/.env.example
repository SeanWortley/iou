# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# URL this backend is reachable at (used to build the GNAP callback URL)
# In dev: your ngrok URL. In prod: your real domain.
BACKEND_URL=https://your-ngrok-url.ngrok.io

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Token from BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHI-your-token-here

# Public URL Telegram will POST webhook events to (same as BACKEND_URL in most cases)
# Update this every time ngrok restarts in dev.
WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# ─── Open Payments Credentials ────────────────────────────────────────────────
# Obtain these from https://wallet.interledger-test.dev
OP_WALLET_ADDRESS=https://ilp.interledger-test.dev/YOUR_HANDLE
OP_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OP_PRIVATE_KEY_PATH=./private.key

# ─── AI parser (Gemini) ───────────────────────────────────────────────────────
# Required: the Python NL parser (backend/src/Interpreter) calls Gemini to turn
# free text into payment intents. Without this every message fails. Free key at
# https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=your-gemini-api-key-here

# Where the backend reaches the Python parser (started by `npm run ai`).
AI_SERVER_URL=http://127.0.0.1:8000/parse

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./iou.db
