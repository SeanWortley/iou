# ── Telegram bot ─────────────────────────────────────────────────────────────
# Get a token from @BotFather (https://t.me/BotFather → /newbot).
BOT_TOKEN=

# Port the webhook server listens on (only used in webhook mode). Default 3000.
PORT=3000

# ── Hosting mode ─────────────────────────────────────────────────────────────
# Leave WEBHOOK_URL empty for long-polling (no ngrok needed — easiest for demos).
#
# To use webhooks with ngrok:
#   1. ngrok http 3000
#   2. copy the https URL it prints (e.g. https://abc123.ngrok-free.app)
#   3. paste it here. The bot registers <WEBHOOK_URL>/webhook with Telegram on boot.
WEBHOOK_URL=

# ── Backend ──────────────────────────────────────────────────────────────────
# Where the /bot/* endpoints (implemented by the backend team) live.
BOT_BACKEND_URL=http://localhost:3001
